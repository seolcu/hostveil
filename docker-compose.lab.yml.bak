services:
  lab:
    build:
      context: .
      dockerfile: docker/lab/Dockerfile
    volumes:
      - .:/workspace:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    ports:
      - "7681:7681"
    environment:
      - HOSTVEIL_LOCALE=en
    privileged: true
  vulnerable-service:
    image: nginx:latest
    container_name: hostveil-lab-target
    ports:
      - "8081:80"
    volumes:
      - /etc/shadow:/mnt/shadow:ro
