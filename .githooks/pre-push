#!/usr/bin/env bash
# .githooks/pre-push
# Warns if the current branch name does not follow naming conventions.
# Does not block the push — just prints a reminder.

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

# Detached HEAD or main: always allow
if [ -z "$branch" ] || [ "$branch" = "main" ]; then
  exit 0
fi

# <type>/<description>  (description may contain letters, numbers, hyphens)
pattern="^(feat|fix|docs|refactor|chore|ci)/.+"

if ! echo "$branch" | grep -qE "$pattern"; then
  echo ""
  echo "  [pre-push] Warning: branch '$branch' does not follow naming conventions."
  echo ""
  echo "  Format : <type>/<short-description>"
  echo "  Types  : feat, fix, docs, refactor, chore, ci"
  echo "  Example: feat/privileged-container-check"
  echo ""
  echo "  Push will continue, but consider renaming this branch."
  echo ""
fi

exit 0
